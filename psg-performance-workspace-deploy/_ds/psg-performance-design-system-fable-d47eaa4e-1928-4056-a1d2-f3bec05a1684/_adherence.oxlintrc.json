{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/pitch/**",
              "examples/guidelines/**",
              "examples/quarterly-update/**",
              "examples/research-hub/**",
              "examples/roles/**",
              "hero-tweaks.jsx",
              "tweaks-panel.jsx"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Virage|Virage Narrow|Virage Condensed|Virage Compact|Virage Extended|Virage Wide|Geist|Geist Mono))/i]",
        "message": "Font not provided by the design system. Available: Virage, Virage Narrow, Virage Condensed, Virage Compact, Virage Extended, Virage Wide, Geist, Geist Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pitch'] > JSXAttribute > JSXIdentifier[name!=/^(?:orientation|detail|extent|zones|zoneLabels|direction|directionLabel|aspect|anchor|tone|lineWeight|surface|pad|area|areaLabel|markers|passes|crest|crestSrc|crestOpacity|crestSize|width|height|style|className|ariaLabel|key|ref|className|style|children)$/]",
        "message": "<Pitch> doesn't accept that prop. Declared props: orientation, detail, extent, zones, zoneLabels, direction, directionLabel, aspect, anchor, tone, lineWeight, surface, pad, area, areaLabel, markers, passes, crest, crestSrc, crestOpacity, crestSize, width, height, style, className, ariaLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pitch'] > JSXAttribute[name.name='orientation'] > Literal[value!=/^(?:landscape|portrait)$/]",
        "message": "<Pitch> orientation must be one of 'landscape' | 'portrait'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pitch'] > JSXAttribute[name.name='detail'] > Literal[value!=/^(?:minimal|standard|full)$/]",
        "message": "<Pitch> detail must be one of 'minimal' | 'standard' | 'full'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pitch'] > JSXAttribute[name.name='extent'] > Literal[value!=/^(?:full|half-left|half-right)$/]",
        "message": "<Pitch> extent must be one of 'full' | 'half-left' | 'half-right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pitch'] > JSXAttribute[name.name='zones'] > Literal[value!=/^(?:none|thirds|halfspaces|grid)$/]",
        "message": "<Pitch> zones must be one of 'none' | 'thirds' | 'halfspaces' | 'grid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pitch'] > JSXAttribute[name.name='direction'] > Literal[value!=/^(?:none|right|left)$/]",
        "message": "<Pitch> direction must be one of 'none' | 'right' | 'left'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pitch'] > JSXAttribute[name.name='anchor'] > Literal[value!=/^(?:center|left|right|top|bottom)$/]",
        "message": "<Pitch> anchor must be one of 'center' | 'left' | 'right' | 'top' | 'bottom'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pitch'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:ink|soft|faint|hero)$/]",
        "message": "<Pitch> tone must be one of 'ink' | 'soft' | 'faint' | 'hero'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pitch'] > JSXAttribute[name.name='crest'] > Literal[value!=/^(?:none|center|corner|corner-tl|corner-tr|corner-bl|corner-br)$/]",
        "message": "<Pitch> crest must be one of 'none' | 'center' | 'corner' | 'corner-tl' | 'corner-tr' | 'corner-bl' | 'corner-br'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
